{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BA Stamp Verify",
  "version": "0.1.0",
  "identifier": "com.bastamp.verify",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BA | Stamp Verify",
        "width": 720,
        "height": 820,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Independent verifier for BA | Stamp blockchain timestamps.",
    "longDescription": "Open-source desktop app that verifies documents anchored by BA | Stamp on the Polygon blockchain. Re-hashes your file locally, rebuilds the Merkle root, and queries the Stamper contract over a public RPC — no account, no tracking, no dependency on bastamp.com.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Aletheia Tech Ltd",
    "copyright": "© 2026 Aletheia Tech Ltd — MIT licensed",
    "homepage": "https://bastamp.com"
  }
}
